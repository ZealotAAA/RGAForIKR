<Window x:Class="RGASDK.DebugTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RGASDK 调试工具 v1.0.0"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas"
        FontSize="13">
    
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="3"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="3"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Foreground" Value="#1565C0"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFEBEE"/>
            <Setter Property="Foreground" Value="#C62828"/>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- 连接区域 -->
        <GroupBox Grid.Row="0" Header="连接设置">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="串口:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Column="1" x:Name="cmbPorts" IsEditable="True"/>
                
                <TextBlock Grid.Column="2" Text="波特率:" VerticalAlignment="Center" Margin="15,5,5,5"/>
                <ComboBox Grid.Column="3" x:Name="cmbBaudRate">
                    <ComboBoxItem Content="9600" Tag="9600"/>
                    <ComboBoxItem Content="115200" Tag="115200"/>
                    <ComboBoxItem Content="921600" Tag="921600" IsSelected="True"/>
                </ComboBox>
                
                <TextBlock Grid.Column="4" Text="从机地址:" VerticalAlignment="Center" Margin="15,5,5,5"/>
                <TextBox Grid.Column="5" x:Name="txtSlaveAddress" Text="1" Width="80"/>
                
                <Button Grid.Column="7" x:Name="btnConnect" Content="连接" Style="{StaticResource SuccessButton}" Click="BtnConnect_Click" Width="100"/>
                <Button Grid.Column="8" x:Name="btnDisconnect" Content="断开" Style="{StaticResource DangerButton}" Click="BtnDisconnect_Click" IsEnabled="False" Width="100"/>
            </Grid>
        </GroupBox>

        <!-- 主功能区域 -->
        <TabControl Grid.Row="1" Margin="5">
            
            <!-- RF控制 -->
            <TabItem Header="RF控制">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="RF 频率">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="频率(Hz):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtRFFrequency" Text="2000000"/>
                                <Button Grid.Column="3" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetRFFrequency_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="RF 中心电压">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="电压(V):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtRFCenterVoltage" Text="10"/>
                                <TextBlock Grid.Column="2" Text="范围: 5~12V" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetRFCenterVoltage_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="RF 电压">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="禁用RF" Click="BtnDisableRF_Click"/>
                                <Button Content="使能RF" Style="{StaticResource ActionButton}" Click="BtnEnableRF_Click"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <GroupBox Header="RF 相位">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="模式:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="cmbRFPhase">
                                    <ComboBoxItem Content="正极性" Tag="1" IsSelected="True"/>
                                    <ComboBoxItem Content="负极性" Tag="2"/>
                                </ComboBox>
                                <Button Grid.Column="3" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetRFPhase_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="RF 电流档位">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="档位:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="cmbRFCurrentRange">
                                    <ComboBoxItem Content="2mA" Tag="1" IsSelected="True"/>
                                    <ComboBoxItem Content="5mA" Tag="2"/>
                                </ComboBox>
                                <Button Grid.Column="3" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetRFCurrentRange_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="读取 RF 状态">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="panelRFStatus" Orientation="Horizontal">
                                    <TextBlock Text="RF频率: " Foreground="Blue"/>
                                    <TextBlock x:Name="txtRFFreqFeedback" Text="-" Margin="0,0,20,0"/>
                                    <TextBlock Text="RF反馈1: " Foreground="Blue"/>
                                    <TextBlock x:Name="txtRFFb1" Text="-" Margin="0,0,20,0"/>
                                    <TextBlock Text="RF反馈2: " Foreground="Blue"/>
                                    <TextBlock x:Name="txtRFFb2" Text="-"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="读取" Style="{StaticResource ActionButton}" Click="BtnReadRFStatus_Click"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 扫描控制 -->
            <TabItem Header="扫描控制">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="扫描参数">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="片段数:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtScanSegmentCount" Text="1"/>
                                
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="起始质量数:"/>
                                <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtScanStartMass" Text="10"/>
                                
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="步数:"/>
                                <TextBox Grid.Row="0" Grid.Column="5" x:Name="txtScanStepCount" Text="50"/>
                                
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="驻留时间(ms):"/>
                                <TextBox Grid.Row="0" Grid.Column="7" x:Name="txtScanDwellTime" Text="20"/>
                                
                                <Button Grid.Row="1" Grid.ColumnSpan="8" Content="设置扫描参数" Style="{StaticResource ActionButton}" HorizontalAlignment="Left" Click="BtnSetScanParams_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="扫描配置">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="扫描片段:"/>
                                <TextBox Grid.Column="1" x:Name="txtScanSegment" Text="1"/>
                                
                                <TextBlock Grid.Column="2" Text="循环次数:"/>
                                <TextBox Grid.Column="3" x:Name="txtScanLoopCount" Text="10"/>
                                
                                <TextBlock Grid.Column="4" Text="建立时间(us):"/>
                                <TextBox Grid.Column="5" x:Name="txtScanSettlingTime" Text="200"/>
                                
                                <TextBlock Grid.Row="1" Text="段间隔(us):"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtScanInterval" Text="10000"/>
                            </Grid>
                        </GroupBox>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button Content="开始扫描" Style="{StaticResource SuccessButton}" Click="BtnStartScan_Click"/>
                            <Button Content="停止扫描" Style="{StaticResource DangerButton}" Click="BtnStopScan_Click"/>
                        </StackPanel>
                        
                        <GroupBox Header="读取扫描数据">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="起始质量:"/>
                                <TextBox Grid.Column="1" x:Name="txtReadStartMass" Text="27.5"/>
                                <TextBlock Grid.Column="2" Text="终止质量:"/>
                                <TextBox Grid.Column="3" x:Name="txtReadEndMass" Text="28.5"/>
                                <TextBlock Grid.Column="4" Text="步长:"/>
                                <TextBox Grid.Column="5" x:Name="txtReadStepSize" Text="0.1"/>
                                <Button Grid.Column="7" Content="读取" Style="{StaticResource ActionButton}" Click="BtnReadScanData_Click"/>
                                
                                <DataGrid Grid.Row="1" Grid.ColumnSpan="8" x:Name="dgScanData" Height="200" IsReadOnly="True" AutoGenerateColumns="True"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 灯丝控制 -->
            <TabItem Header="灯丝控制">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="灯丝选择">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="灯丝:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="cmbFilamentSelect">
                                    <ComboBoxItem Content="灯丝A" Tag="1" IsSelected="True"/>
                                    <ComboBoxItem Content="灯丝B" Tag="2"/>
                                </ComboBox>
                                <Button Grid.Column="3" Content="选择" Style="{StaticResource ActionButton}" Click="BtnSelectFilament_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="发射电流">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="电流(uA):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtFilamentEmission" Text="1000"/>
                                <TextBlock Grid.Column="2" Text="范围: 0~2000" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetFilamentEmission_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="放电时间">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="时间(us):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtDischargeTime" Text="200"/>
                                <Button Grid.Column="3" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetDischargeTime_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="电流安全值">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="电流(A):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtFilamentSafety" Text="4.6"/>
                                <Button Grid.Column="3" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetFilamentSafety_Click"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- EM板控制 -->
            <TabItem Header="EM板控制">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="DET_HV 电压">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="电压(V):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtDETHV" Text="200"/>
                                <TextBlock Grid.Column="2" Text="范围: 0~2200" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetDETHV_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="Anode 电压">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="电压(V):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtAnodeVoltage" Text="200"/>
                                <TextBlock Grid.Column="2" Text="范围: 0~3000" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetAnodeVoltage_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="Focus 电压">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="电压(V):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtFocusVoltage" Text="10"/>
                                <TextBlock Grid.Column="2" Text="范围: 0~320" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetFocusVoltage_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="Electron Energy">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="能量(eV):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtElectronEnergy" Text="70"/>
                                <TextBlock Grid.Column="2" Text="范围: 0~320" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetElectronEnergy_Click"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- FPGA控制 -->
            <TabItem Header="FPGA控制">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="检测器 OutB">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="值:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtOutB" Text="700"/>
                                <TextBlock Grid.Column="2" Text="范围: 0~4096" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetOutB_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="OutC (Lower)">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="值:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtOutC" Text="500"/>
                                <TextBlock Grid.Column="2" Text="范围: 0~4096" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetOutC_Click"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="OutD (Upper)">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="值:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtOutD" Text="3500"/>
                                <TextBlock Grid.Column="2" Text="范围: 0~4096" Foreground="Gray" Margin="10,0"/>
                                <Button Grid.Column="4" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetOutD_Click"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 系统控制 -->
            <TabItem Header="系统控制">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="波特率设置">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="波特率:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="cmbSetBaudRate">
                                    <ComboBoxItem Content="9600" Tag="1"/>
                                    <ComboBoxItem Content="115200" Tag="2"/>
                                    <ComboBoxItem Content="921600" Tag="3" IsSelected="True"/>
                                </ComboBox>
                                <Button Grid.Column="3" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetBaudRate_Click"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="真空系数校正">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="系数:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtVacuumCoeff" Text="0.000222"/>
                                <Button Grid.Column="3" Content="设置" Style="{StaticResource ActionButton}" Click="BtnSetVacuumCoeff_Click"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="发送原始数据">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="数据(空格分隔的十六进制):" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtRawData" Text="01 03 00 0C 00 01 44 09"/>
                                <Button Grid.Column="2" Content="发送" Style="{StaticResource ActionButton}" Click="BtnSendRaw_Click"/>
                            </Grid>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="保存参数" Style="{StaticResource ActionButton}" Click="BtnSaveParams_Click"/>
                            <Button Content="清除错误" Style="{StaticResource ActionButton}" Click="BtnClearError_Click"/>
                            <Button Content="开始校验" Style="{StaticResource ActionButton}" Click="BtnStartCalibration_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 读取操作 -->
            <TabItem Header="读取操作">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="读取设备状态">
                            <Button Content="读取完整状态" Style="{StaticResource ActionButton}" Click="BtnReadStatus_Click"/>
                        </GroupBox>
                        
                        <GroupBox Header="读取状态数据">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="PS心跳:"/>
                                    <TextBox x:Name="txtPSHeartbeat" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Content="读取" Click="BtnReadPSHeartbeat_Click"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="SYS心跳:"/>
                                    <TextBox x:Name="txtSYSHeartbeat" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Content="读取" Click="BtnReadSYSHeartbeat_Click"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="真空度(Torr):"/>
                                    <TextBox x:Name="txtVacuum" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Content="读取" Click="BtnReadVacuum_Click"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="RF频率(Hz):"/>
                                    <TextBox x:Name="txtRFFreq" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Content="读取" Click="BtnReadRFFreq_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="读取电压电流">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Anode电压(V):"/>
                                    <TextBox x:Name="txtAnodeVoltRead" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Content="读取" Click="BtnReadAnodeVoltage_Click"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="EM电压(V):"/>
                                    <TextBox x:Name="txtEMVoltRead" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Content="读取" Click="BtnReadEMVoltage_Click"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="灯丝电流(A):"/>
                                    <TextBox x:Name="txtFilamentCurr" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Content="读取" Click="BtnReadFilamentCurrent_Click"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="ElectronEnergy(eV):"/>
                                    <TextBox x:Name="txtElectronE" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Content="读取" Click="BtnReadElectronEnergy_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 设备初始化 -->
            <TabItem Header="设备初始化">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="EM板配置">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="DET_HV:"/>
                                <TextBox Grid.Column="1" x:Name="txtInitDETHV" Text="200"/>
                                <TextBlock Grid.Column="2" Text="Anode:"/>
                                <TextBox Grid.Column="3" x:Name="txtInitAnode" Text="200"/>
                                <TextBlock Grid.Column="4" Text="Focus:"/>
                                <TextBox Grid.Column="5" x:Name="txtInitFocus" Text="10"/>
                                <TextBlock Grid.Column="6" Text="ElectronE:"/>
                                <TextBox Grid.Column="7" x:Name="txtInitElectronE" Text="70"/>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="RF配置">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="频率(Hz):"/>
                                <TextBox Grid.Column="1" x:Name="txtInitFreq" Text="2000000"/>
                                <TextBlock Grid.Column="2" Text="中心电压(V):"/>
                                <TextBox Grid.Column="3" x:Name="txtInitCenterV" Text="5"/>
                                <ComboBox Grid.Column="4" x:Name="cmbInitPhase" Width="120">
                                    <ComboBoxItem Content="正极性" Tag="Positive" IsSelected="True"/>
                                    <ComboBoxItem Content="负极性" Tag="Negative"/>
                                </ComboBox>
                            </Grid>
                        </GroupBox>
                        
                        <GroupBox Header="灯丝配置">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="灯丝:"/>
                                <ComboBox Grid.Column="1" x:Name="cmbInitFilament">
                                    <ComboBoxItem Content="灯丝A" Tag="FilamentA" IsSelected="True"/>
                                    <ComboBoxItem Content="灯丝B" Tag="FilamentB"/>
                                </ComboBox>
                                <TextBlock Grid.Column="2" Text="发射电流(uA):"/>
                                <TextBox Grid.Column="3" x:Name="txtInitEmission" Text="1000"/>
                                <TextBlock Grid.Column="4" Text="放电时间(us):"/>
                                <TextBox Grid.Column="5" x:Name="txtInitDischarge" Text="200"/>
                            </Grid>
                        </GroupBox>
                        
                        <Button Content="一键初始化设备" Style="{StaticResource SuccessButton}" Height="50" FontSize="16" Click="BtnInitializeDevice_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
        </TabControl>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="2" Header="操作日志">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox x:Name="lstLog" FontFamily="Consolas" FontSize="12"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Content="清空日志" Click="BtnClearLog_Click"/>
                    <CheckBox x:Name="chkAutoScroll" Content="自动滚动" IsChecked="True" Margin="10,0"/>
                    <TextBlock Text="状态:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                    <TextBlock x:Name="txtStatus" Text="未连接" Foreground="Gray" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
